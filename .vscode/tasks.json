{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "TypeScript: watch",
			"command": "npm run watch",
			"isBackground": true,
			"problemMatcher": [
				"$tsc-watch"
			],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "TypeScript: build",
			"command": "npm run build",
			"isBackground": true,
			"problemMatcher": [
				"$tsc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
		},
		{
			"label": "Build",
			"dependsOn": [
				"TypeScript: build",
				"CMake: build"
			]
		}
	]
}